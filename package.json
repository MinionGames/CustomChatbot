{
  "name": "customchatbot",
  "version": "1.0.0",
  "description": "",
  "main": "chatbot.js",
  "scripts": {
    "start": "node backend/server.js",
    "dev": "npm run frontend:dev",
    "build": "npm run frontend:build",
    "frontend:dev": "vite --config frontend/vite.config.mjs",
    "frontend:build": "npm run frontend:build:site && npm run frontend:build:embed",
    "frontend:build:site": "vite build --config frontend/vite.config.mjs",
    "frontend:build:embed": "vite build --config frontend/vite.chatbot.config.mjs",
    "frontend:preview": "vite preview --config frontend/vite.config.mjs",
    "test": "node --test tests/**/*.test.js",
    "check": "node --check backend/server.js && npm run test"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MinionGames/CustomChatbot.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/MinionGames/CustomChatbot/issues"
  },
  "homepage": "https://github.com/MinionGames/CustomChatbot#readme",
  "dependencies": {
    "@langchain/core": "^1.2.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "langchain": "^1.5.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.105.0",
    "@tailwindcss/vite": "^4.3.1",
    "@vitejs/plugin-react": "^6.0.3",
    "supertest": "^7.2.2",
    "tailwindcss": "^4.3.1",
    "vite": "^8.1.0",
    "vite-plugin-css-injected-by-js": "^3.5.2"
  }
}
