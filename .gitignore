.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Diagnostic reports
report.[0-9]*.[0-9]*.[0-9]*.[0-9]*.json

# Runtime data
pids
*.pid
*.seed
*.pid.lock

# Directory for instrumented libs generated by jscoverage/JSCover
lib-cov

# Coverage directory used by tools like istanbul or jest
coverage
*.lcov

# nyc test coverage
.nyc_output

# Build outputs (Uncomment if you compile TS/Next/Nuxt)
# dist/
# build/
# .next/
# .nuxt/

# TypeScript cache
*.tsbuildinfo

# Optional npm cache directory
.npm

# Optional eslint cache
.eslintcache

# Optional Stylelint cache
.stylelintcache

# lock file maintenance (Uncomment if you want to ignore lockfiles, though not recommended for apps)
# package-lock.json
# yarn.lock
# pnpm-lock.yaml

# OS files (Highly recommended)
.DS_Store
Thumbs.db